{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "RAILPACK",
		"buildCommand": "pnpm run build"
	},
	"deploy": {
		"cronSchedule": "0 0 1 * *",
		"preDeployCommand": ["pnpm run transform && pnpm run fetch"],
		"startCommand": "pnpm run sync",
		"healthcheckPath": "/",
		"healthcheckTimeout": 100,
		"restartPolicyType": "NEVER"
	}
}
